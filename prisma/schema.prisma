generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  phone     String
  address   String
  role      Role
  professor Professor?
  student   Student?
  createdAt DateTime  @default(now())
}

model Professor {
  id                  Int       @id @default(autoincrement())
  userId              Int       @unique
  specialty           String
  yearsOfExperience   Int
  availableSchedules  String
  user                User      @relation(fields: [userId], references: [id])
  classes             Class[]
  students            Student[]
}

model Class {
  id          Int       @id @default(autoincrement())
  name        String
  level       String
  minAge      Int
  maxAge      Int
  description String?
  schedule    String
  capacity    Int
  professorId Int
  professor   Professor @relation(fields: [professorId], references: [id])
  students    Student[]
}

model Student {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  birthDate      DateTime
  level          String
  medicalNotes   String?
  classId        Int?
  professorId    Int?
  insurancePaid  Boolean   @default(false)
  fatherName     String?
  fatherPhone    String?
  motherName     String?
  motherPhone    String?
  user           User      @relation(fields: [userId], references: [id])
  class          Class?    @relation(fields: [classId], references: [id])
  professor      Professor? @relation(fields: [professorId], references: [id])
  insurance      MedicalInsurance?
  competitions   StudentCompetition[]
}

model MedicalInsurance {
  id             Int       @id @default(autoincrement())
  studentId      Int       @unique
  dni            String
  paymentDate    DateTime
  policyNumber   String
  validFrom      DateTime
  validUntil     DateTime
  notes          String?
  student        Student   @relation(fields: [studentId], references: [id])
}

model Competition {
  id                      Int                  @id @default(autoincrement())
  name                    String
  registrationDeadline    DateTime
  competitionDate         DateTime
  location                String
  address                 String
  category                String
  level                   String
  description             String?
  studentCompetitions     StudentCompetition[]
}

model StudentCompetition {
  id            Int         @id @default(autoincrement())
  studentId     Int
  competitionId Int
  result        String?
  student       Student     @relation(fields: [studentId], references: [id])
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@unique([studentId, competitionId])
}

enum Role {
  ADMIN
  PROFESSOR
  STUDENT
}
